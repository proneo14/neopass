{
  "manifest_version": 2,
  "name": "LGI Pass",
  "version": "1.0.0",
  "description": "LGI Pass - secure password autofill",
  "permissions": [
    "storage",
    "nativeMessaging",
    "activeTab",
    "tabs",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lgipass@lancastergroup.com",
      "strict_min_version": "55.0"
    }
  }
}
